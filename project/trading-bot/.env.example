# Copy to .env and fill in with your Alpaca PAPER trading keys —
# https://app.alpaca.markets/paper/dashboard/overview -> API Keys.
# Do NOT put live-account keys here. ALPACA_BASE_URL must stay pointed at
# paper-api.alpaca.markets — every script in this project refuses to run
# otherwise (see common.py's assert_paper_mode()).

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

TRADING_SYMBOL=SPY
