# Copy to .env and fill in. Never commit the real .env file.

# Free tier: https://www.pexels.com/api/ (200 requests/hour, 20,000/month)
PEXELS_API_KEY=

# https://elevenlabs.io — Starter plan (~£4/mo) gives 30k characters/month,
# enough for roughly 15-20 one-minute scripts. Free tier gives 10k chars/month.
ELEVENLABS_API_KEY=
# Optional: pick a voice from https://elevenlabs.io/app/voice-library
# Defaults to "Rachel" (21m00Tcm4TlvDq8ikWAM) if unset.
ELEVENLABS_VOICE_ID=

# Set to 1 to run the whole pipeline offline with synthetic placeholder
# footage/audio (no network, no API keys needed) — useful for a dry run.
PIPELINE_MOCK=0
